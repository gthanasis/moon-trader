# Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# LLM provider — 'openai' (default) or 'anthropic'
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Database
# Local-dev default. Change the credentials for any non-local deployment.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trader?connection_limit=10

# API server
# API_PORT=4000
# API_HOST=127.0.0.1                  # loopback only; set 0.0.0.0 only inside Docker
# WEB_ORIGIN=http://localhost:3000    # allowed CORS origin for the API
# API_AUTH_TOKEN=                     # set a strong secret when the API is reachable beyond
                                      # loopback — mutating routes then require
                                      # `Authorization: Bearer <token>`

# Trading config
TOTAL_CAPITAL=1000
AUTO_TRADE_LIMIT=50
COINS=BTC/USDT,ETH/USDT
TIMEFRAME=15m
OHLCV_LIMIT=100
CRON_EXPRESSION=*/15 * * * *
PAPER=true

# Risk management (optional — defaults shown)
RISK_PER_TRADE_PCT=0.01       # fraction of capital risked per trade when stop-loss is set
MIN_CONFIDENCE=0.6             # minimum LLM confidence to execute a non-hold decision
MAX_POSITIONS=5                # max simultaneous open positions
DAILY_LOSS_LIMIT_PCT=0.05     # halt new buys if daily realised loss exceeds this fraction
FEE_RATE=0.001                 # exchange fee per trade (0.1% = Binance taker)
SLIPPAGE_BPS=5                 # paper-mode slippage in basis points

# Data sources (optional — CryptoPanic disabled if not set, Fear & Greed always active)
# CRYPTOPANIC_API_TOKEN=your_token

# Telegram (optional — bot disabled if not set)
# TELEGRAM_BOT_TOKEN=123456789:your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# --- Deployment (docker-compose.prod.yml) ---------------------------------
# Password for the Postgres container. DATABASE_URL above is overridden by
# compose to point at the `postgres` service — this is the only DB value
# you set for a containerised deploy.
POSTGRES_PASSWORD=change_me
# Where the browser reaches the API (baked into the web bundle at build).
# Default suits the SSH-tunnel setup in DEPLOY.md; leave as-is normally.
# NEXT_PUBLIC_API_URL=http://localhost:4000
# Must match API_AUTH_TOKEN above when the API requires authentication.
# NEXT_PUBLIC_API_TOKEN=
