{
  "name": "@trader/api",
  "version": "0.1.0",
  "private": true,
  "description": "Trading engine, LLM evaluation, backtesting, and HTTP API for the trader bot.",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "narration:backfill": "tsx src/narration/backfill.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^5.22.0",
    "ccxt": "^4.5.54",
    "dotenv": "^16.6.1",
    "grammy": "^1.43.0",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/express": "^4.17.25",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "prisma": "^5.22.0",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
